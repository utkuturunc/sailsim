{
  "name": "sailboat-force-lab",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun lib/tooling/build.ts",
    "check": "bun run format:check && bun run typecheck && bun test && bun run build",
    "dev": "bun run build && bun --watch lib/tooling/server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "bun run build && bun lib/tooling/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
